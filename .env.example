# Server-side only — never exposed to the client.
# Preferred: OpenRouter (any cheap model works; see OPENROUTER_MODEL)
OPENROUTER_API_KEY=sk-or-...
# Optional override (default: google/gemini-2.5-flash)
OPENROUTER_MODEL=google/gemini-2.5-flash

# Fallback: direct Anthropic API (used only if OPENROUTER_API_KEY is unset)
# ANTHROPIC_API_KEY=sk-ant-...
